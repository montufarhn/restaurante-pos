# === CONFIGURACIÓN DE PRODUCCIÓN ===
# ⚠️  EJEMPLO - Copiar y editar para tu entorno
# Usar esto como referencia para configurar en Render.com

NODE_ENV=production
PORT=3000

# === BASE DE DATOS PRODUCCIÓN (Supabase) ===
USE_LOCAL_DB=false
SUPABASE_ENABLED=true

# Obtener de: Supabase → Settings → Database → Connection Pooling → postgres://...
# Reemplazar [PASSWORD] con tu contraseña de Supabase
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# === SEGURIDAD PRODUCCIÓN ===
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRÍTICO: Debe ser único, diferente para cada deployment
SESSION_SECRET=tu-secret-aleatorio-de-32-caracteres-minimo-muy-largo

SESSION_TIMEOUT_HOURS=8
SALT_ROUNDS=10

# === DOMINIO ===
# Cambiar a tu DOMINIO REAL en Render
# Formato: https://restaurante-pos-xxxx.onrender.com
CORS_ORIGIN=https://tu-dominio-production.onrender.com

# === LOGGING Y MONITOREO ===
LOG_LEVEL=warn
NO_OPEN=true

# === OPCIONAL: Para futuros features ===
# SENTRY_DSN=your-sentry-project-id
# DATADOG_API_KEY=your-datadog-key
